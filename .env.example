# Environment Variables Template
# Copy this to .env and fill in with your actual values
# NEVER commit .env to Git! Add to .gitignore

# ========== BACKEND API ==========
NODE_ENV=development
PORT=3000
API_HOST=localhost

# ========== DATABASE ==========
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/zkas_dev
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zkas_dev

# ========== CRYPTO SERVICE ==========
CRYPTO_SERVICE_URL=http://localhost:5000
FLASK_ENV=development
CRYPTO_PORT=5000

# ========== SECURITY ==========
JWT_SECRET=your-super-secret-key-change-this-in-production
CORS_ORIGIN=http://localhost:3000
SESSION_SECRET=your-session-secret-key

# ========== FRONTEND ==========
REACT_APP_API_URL=http://localhost:3000
REACT_APP_CRYPTO_URL=http://localhost:5000
REACT_APP_ENV=development

# ========== PRODUCTION (use these on deployed platforms) ==========
# NODE_ENV=production
# DATABASE_URL=postgresql://username:password@prod-db-host:5432/zkas
# REACT_APP_API_URL=https://your-api-domain.com
# REACT_APP_CRYPTO_URL=https://your-crypto-domain.com
# JWT_SECRET=<generate-strong-random-string>
# CORS_ORIGIN=https://your-frontend-domain.com

# ========== OPTIONAL: Email Service ==========
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ========== OPTIONAL: Monitoring ==========
# SENTRY_DSN=https://xxx@sentry.io/12345
# LOG_LEVEL=info

# ========== OPTIONAL: Third-party Services ==========
# AWS_ACCESS_KEY_ID=xxxxx
# AWS_SECRET_ACCESS_KEY=xxxxx
# STRIPE_PUBLIC_KEY=pk_xxxxx
# STRIPE_SECRET_KEY=sk_xxxxx
